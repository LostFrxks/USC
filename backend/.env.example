# Copy to `.env` and fill values (do NOT commit real secrets)

# Database
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# API
APP_ENV=dev
API_PREFIX=/api
# CORS (allow frontend from localhost + LAN IP)
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOW_ORIGIN_REGEX=^https?://(?:localhost|127\\.0\\.0\\.1|\\d{1,3}(?:\\.\\d{1,3}){3})(?::\\d+)?$

# JWT
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=30
# Refresh cookie
# AUTH_REFRESH_COOKIE_NAME=usc_refresh_token
# AUTH_COOKIE_PATH=/
# AUTH_COOKIE_DOMAIN=
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_SECURE=false

# Auth security controls
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_FAIL_CLOSED=false
# CAPTCHA_PROVIDER=stub
# CAPTCHA_STUB_TOKEN=pass-captcha
# CAPTCHA_REQUIRED_TTL_SECONDS=86400
# AUTH_FAIL_WINDOW_SECONDS=86400
# AUTH_FAIL_THRESHOLD=5
# AUTH_LOCKOUT_STEP1_SECONDS=900
# AUTH_LOCKOUT_STEP2_SECONDS=3600
# AUTH_LOCKOUT_STEP3_SECONDS=86400
# METRICS_ENABLED=true

# Sentry (optional)
# SENTRY_DSN_BACKEND=
# SENTRY_ENVIRONMENT=dev
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.0

# Redis / cache
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_PREFIX=usc
# REDIS_TIMEOUT_SECONDS=1.5
# CACHE_TTL_CATEGORIES=180
# CACHE_TTL_PRODUCTS=45
# CACHE_TTL_COMPANIES=60
# CACHE_TTL_MEMBERSHIPS=60
# CACHE_TTL_SUPPLIERS=60
# CACHE_TTL_PROFILE_ME=60
# CACHE_TTL_NOTIFICATIONS=45
# CACHE_TTL_ORDERS_LIST=30
# CACHE_TTL_ORDER_DETAIL=30
# CACHE_TTL_ORDERS_BOX=30
# CACHE_TTL_DELIVERIES=45
# CACHE_TTL_ANALYTICS_SUMMARY=45
# CACHE_TTL_ANALYTICS_INSIGHTS=120
# CACHE_TTL_ANALYTICS_ASSISTANT=45

# SMTP (optional; if empty -> email code returns as `code` in API response for dev)
# Gmail example (recommended: App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your_email@gmail.com
# SMTP_STARTTLS=true
# SMTP_USE_SSL=false

# Email verification code behavior
# EMAIL_CODE_EXPIRES_SECONDS=300
# EMAIL_CODE_LENGTH=6
# EMAIL_CODE_DEV_FALLBACK=true
# Set EMAIL_CODE_DEV_FALLBACK=false in staging/prod to require real SMTP sending.

# SSL example (port 465):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your_email@gmail.com
# SMTP_STARTTLS=false
# SMTP_USE_SSL=true

# LLM (OpenAI) for analytics assistant
# If empty, backend uses local fallback logic.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=20
