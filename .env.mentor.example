# Mentor testing profile (Netlify frontend + public backend)
# Copy this file to .env on backend host and replace placeholder values.

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
DATABASE_URL=postgresql+psycopg2://usc:usc123@postgres:5432/usc_db
REDIS_URL=redis://redis:6379/0
API_PREFIX=/api

# Replace with your real Netlify site URL.
# Example: https://usc-mentor-demo.netlify.app
CORS_ALLOW_ORIGINS=https://your-netlify-site.netlify.app

# Allows main and preview Netlify domains for this site:
# https://your-site.netlify.app
# https://deploy-preview-1--your-site.netlify.app
CORS_ALLOW_ORIGIN_REGEX=^https://(?:[a-z0-9-]+--)?your-netlify-site\\.netlify\\.app$

EMAIL_CODE_DEV_FALLBACK=true
AUTO_SEED_DEMO=false
METRICS_ENABLED=true

SENTRY_DSN_BACKEND=
SENTRY_ENVIRONMENT=mentor
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
