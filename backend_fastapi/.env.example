# Copy to `.env` and fill values (do NOT commit real secrets)

# Database
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
# Docker local example:
# DATABASE_URL=postgresql+psycopg2://usc:usc123@127.0.0.1:5432/usc_db

# API
API_PREFIX=/api

# JWT
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=30

# SMTP (optional; if empty -> email code returns as `code` in API response for dev)
# Gmail example (recommended: App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your_email@gmail.com
# SMTP_STARTTLS=true
# SMTP_USE_SSL=false

# SSL example (port 465):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your_email@gmail.com
# SMTP_STARTTLS=false
# SMTP_USE_SSL=true

# LLM (OpenAI) for analytics assistant
# If empty, backend uses local fallback logic.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=20

# Redis cache (optional for local MVP)
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_PREFIX=usc
# REDIS_TIMEOUT_SECONDS=1.5
# CACHE_TTL_ANALYTICS_SUMMARY=45
# CACHE_TTL_ANALYTICS_INSIGHTS=120
# CACHE_TTL_ANALYTICS_ASSISTANT=45
# CACHE_TTL_CATEGORIES=180
# CACHE_TTL_PRODUCTS=45
# CACHE_TTL_SUPPLIERS=60
# CACHE_TTL_COMPANIES=45
# CACHE_TTL_MEMBERSHIPS=45
# CACHE_TTL_PROFILE_ME=20
# CACHE_TTL_NOTIFICATIONS=20
# CACHE_TTL_ORDERS_LIST=20
# CACHE_TTL_ORDER_DETAIL=20
# CACHE_TTL_ORDERS_BOX=20
# CACHE_TTL_DELIVERIES=20

# Unified LLM provider (gemini|openai)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
