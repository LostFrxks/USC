{
  "name": "frontend_mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "eas:login": "npx eas-cli login",
    "eas:build:preview": "npx eas-cli build -p android --profile preview",
    "eas:build:apk": "npx eas-cli build -p android --profile production-apk",
    "eas:build:production": "npx eas-cli build -p android --profile production",
    "maestro:buyer": "maestro test .maestro/buyer-smoke.yaml",
    "maestro:supplier": "maestro test .maestro/supplier-smoke.yaml",
    "maestro:auth-reset": "maestro test .maestro/auth-reset-smoke.yaml",
    "maestro:onboarding": "maestro test .maestro/onboarding-smoke.yaml",
    "maestro:golden": "npm run maestro:buyer && npm run maestro:supplier && npm run maestro:auth-reset && npm run maestro:onboarding"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "^5.90.12",
    "@usc/core": "file:../shared/usc-core",
    "expo": "~54.0.22",
    "expo-linking": "~8.0.8",
    "expo-location": "~19.0.7",
    "expo-router": "~6.0.14",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.8",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.66.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.18",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-jest": "^30.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.7",
    "jest": "^30.2.0",
    "jest-expo": "~54.0.13",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@babel/runtime/(.*)$": "<rootDir>/node_modules/@babel/runtime/$1"
    }
  }
}
